PORT=5000
NODE_ENV=production

MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=PlacementPilot
REDIS_URL=redis://default:<password>@<host>:<port>

JWT_SECRET=<generate-a-random-secret-here>
JWT_EXPIRES_IN=7d

# Local Ollama (for local dev only — not needed on Render)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Groq Cloud (for Render deployment — comment out GROQ_API_KEY to use Ollama locally)
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
GROQ_MODEL=llama3-8b-8192

# Set to your Vercel frontend URL in production
CLIENT_URL=https://hackathonmain.vercel.app
CORS_ORIGIN=https://hackathonmain.vercel.app
